{
  "name": "valm-js",
  "version": "0.1.6",
  "description": "Browser media stream manager — camera, microphone, screen share, recording, transcription, and video effects",
  "keywords": [
    "media",
    "camera",
    "microphone",
    "webrtc",
    "mediastream",
    "screen-share",
    "recording",
    "video-effects",
    "background-blur",
    "virtual-background",
    "mediapipe",
    "transcription",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "!dist/**/*.map"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "eventemitter3": "^5.0.0"
  },
  "peerDependencies": {
    "@mediapipe/tasks-vision": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "@mediapipe/tasks-vision": { "optional": true }
  },
  "devDependencies": {
    "@mediapipe/tasks-vision": "^0.10.0",
    "typescript": "^5.5.3",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0"
  }
}
